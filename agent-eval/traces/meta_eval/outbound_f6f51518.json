            "tool_name": "transfer_to_human",
            "arguments": {
              "order_id": "MT20260519501",
              "reason": "订单MT20260519501烤鸭套餐包装破损、汤汁洒漏，客户要求处理补偿",
              "priority": "urgent"
            },
            "result": {
              "transfer_id": "xfer_3030",
