              "merchant_name": "卤肉先生",
              "items": [
                "鸡排饭",
                "紫菜汤",
                "可乐"
              ],
              "total_price": 35.5,
              "delivery_address": "朝阳区国贸CBD 银泰中心 21楼2108",
              "delivery_time": "12:10",
              "actual_delivery_time": null,
              "status": "delivering",
              "rider_name": "吴师傅",
              "rider_phone": null,
              "created_at": "2026-05-19 12:50:02",
              "notes": ""
            },
            "error": null,
            "latency_ms": 0,
            "fault_injected": false,
