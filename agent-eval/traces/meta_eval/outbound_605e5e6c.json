    "messages": [
      {
        "turn": 1,
        "role": "agent",
        "content": "您好，马先生。我是美团客服，想耽误您1-2分钟做个简短的用餐体验回访，请问现在方便吗？",
        "tool_calls": [
          {
            "id": "4fa31b39",
            "tool_name": "query_order",
            "arguments": {
              "order_id": "MT20260519701"
            },
