        "metadata": {}
      },
      {
        "turn": 2,
        "role": "agent",
        "content": "您好！请问您是王女士吗？我这边是美团客服，关于您今天的订单有个问题想跟您确认一下。",
        "tool_calls": [],
        "timestamp": "2026-05-17T21:47:48.137087",
        "metadata": {}
      },
      {
        "turn": 2,
        "role": "user",
        "content": "对，我是。什么事啊？",
