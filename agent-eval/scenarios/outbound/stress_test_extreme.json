      "required_actions": [
        "record_escalation"
      ],
      "is_optional": true,
      "completion_condition": "客户同意先处理B"
    },
    {
      "step_id": "acknowledge_issue_b",
      "order": 11,
      "instruction": "转向订单B（MT20260517198，延迟45分钟+汤洒了）：表达歉意，确认问题。同样不能承认过错",
      "required_actions": [
        "apologize_carefully",
        "restate_issue_b"
      ],
      "forbidden_words": [
        "是我们的错",
        "骑手的问题",
        "商家失误",
        "我方过错"
      ],
      "completion_condition": "客户确认订单B问题"
