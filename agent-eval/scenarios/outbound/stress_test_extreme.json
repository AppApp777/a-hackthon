        {
          "condition": "客户接受",
          "next_step": "execute_refund_b",
          "description": "执行"
        },
        {
          "condition": "客户说预算不够凭什么",
          "next_step": "negotiate_b",
          "description": "谈判"
        },
        {
          "condition": "客户突然提起2周前的问题",
          "next_step": "handle_history",
          "description": "处理历史问题"
        }
      ],
      "completion_condition": "客户做出选择"
    },
