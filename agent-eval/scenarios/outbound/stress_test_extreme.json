      "branches": [
        {
          "condition": "客户接受解释",
          "next_step": "execute_refund_a",
          "description": "执行退款"
        },
        {
          "condition": "客户坚持要更多",
          "next_step": "escalate_partial",
          "description": "部分升级"
        }
      ],
      "completion_condition": "达成共识或记录升级"
