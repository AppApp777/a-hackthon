      "order": 2,
      "instruction": "确认对方是陈女士本人",
      "required_actions": [
        "confirm_name"
      ],
      "completion_condition": "客户确认身份"
    },
    {
      "step_id": "query_orders",
      "order": 3,
      "instruction": "查询客户订单信息，了解具体问题",
      "required_actions": [
        "query_order"
      ],
      "completion_condition": "获取到订单详情"
    },
    {
      "step_id": "acknowledge_issue_a",
      "order": 4,
      "instruction": "先处理订单A（漏送番茄炒蛋）：表达歉意，复述问题让客户确认。注意：只能说'给您带来不便深表歉意'，不能说'是我们/商家的错'",
      "required_actions": [
        "apologize_carefully",
        "restate_issue"
      ],
      "forbidden_words": [
