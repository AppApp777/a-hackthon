  },
  "canonical_intent": [
    {
      "id": "R_appeal_right",
      "content": "必须告知骑手有申诉权利和具体申诉路径",
      "mutable": false,
      "source": "scenario_policy",
      "keywords": [
        "申诉",
        "提交",
        "App",
        "工单"
      ],
      "must_appear_before_step": "wrap_up"
    },
    {
      "id": "R_factual_warning",
      "content": "警告必须基于真实数据，不能编造或夸大违规事实",
      "mutable": false,
      "source": "scenario_policy",
      "keywords": [
        "30%",
        "拒单率",
        "8%",
        "客诉"
      ]
    }
