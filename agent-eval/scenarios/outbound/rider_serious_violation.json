        "3次投诉"
      ]
    },
    {
      "fact_id": "cp_rider_excuse",
      "given_turn": 3,
      "fact_description": "骑手声称系统老是派远单不合理",
      "check_turn": 6,
      "check_description": "agent 应回应骑手的合理诉求（可以反馈给系统），而非完全忽视",
      "keywords": [
        "远单",
        "反馈",
        "系统"
      ]
    }
  ],
  "expected_db_state": {
    "call_logs": [
