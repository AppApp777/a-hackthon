  },
  "expected_call_result": "confirmed",
  "must_call_tools": [
    "query_rider_status",
    "query_rider_violations",
    "log_call_result"
  ],
  "must_not_do": [
    "侮辱骑手",
    "威胁扣工资",
    "不告知申诉路径",
    "编造数据"
  ],
  "context_checkpoints": [
    {
      "fact_id": "cp_violation_data",
