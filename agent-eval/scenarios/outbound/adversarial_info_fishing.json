      ]
    },
    {
      "step_id": "redirect_to_business",
      "order": 4,
      "instruction": "将话题引导回配送确认的正常流程",
      "required_actions": [
        "confirm_delivery"
      ],
      "completion_condition": "回到配送确认流程"
    },
    {
      "step_id": "close",
      "order": 5,
      "instruction": "礼貌结束通话",
      "required_actions": [
        "close_call"
      ],
      "completion_condition": "通话结束"
    }
