{
  "id": "outbound_rider_warning_01",
  "name": "单数未达标警告-配合型",
  "domain": "outbound_call",
  "call_type": "rider_notify",
  "difficulty": "easy",
  "description": "站长致电骑手，告知连续2天未达到飞毛腿最低单数（5单/天），再不达标将自动取消合同。骑手配合型，承认最近有事。",
  "call_purpose": "告知骑手连续2天未达标，说明后果，确认后续计划",
  "call_context": {
    "order_id": "",
    "customer_name": "赵刚",
    "customer_phone": "13700137001",
    "order_items": [],
    "delivery_address": "",
    "delivery_time": "",
    "issue_type": "",
    "issue_detail": "",
    "rider_name": "赵刚",
    "merchant_name": "",
    "compensation_budget": 0
  },
  "instruction_steps": [
    {
      "step_id": "open",
      "order": 1,
      "instruction": "自报身份（站长），确认对方是赵刚",
      "required_actions": [
        "self_identify",
        "confirm_identity"
      ],
      "completion_condition": "骑手确认身份"
    },
    {
      "step_id": "inform_situation",
      "order": 2,
      "instruction": "如实告知骑手连续2天未达到飞毛腿最低5单/天的要求，引用具体数据（第1天3单、第2天2单）",
      "required_actions": [
        "inform_underperformance"
      ],
      "completion_condition": "骑手表示知道了"
    },
    {
      "step_id": "explain_consequence",
      "order": 3,
      "instruction": "说明后果：如果明天仍未达标，系统将自动取消飞毛腿合同，恢复普通骑手派单",
      "required_actions": [
        "explain_consequence"
      ],
      "completion_condition": "骑手表示理解后果"
    },
    {
      "step_id": "confirm_plan",
      "order": 4,
      "instruction": "询问骑手后续计划，确认明天是否能正常出勤达标",
      "required_actions": [
        "ask_plan"
      ],
      "completion_condition": "骑手给出明确回复"
    },
    {
      "step_id": "wrap_up",
      "order": 5,
      "instruction": "确认无其他问题，鼓励骑手，礼貌结束通话，记录结果",
      "required_actions": [
        "encourage_rider",
        "say_goodbye",
        "log_result"
      ],
      "completion_condition": "通话结束"
    }
  ],
  "mandatory_opening": "你好，请问是赵刚吗？我是站长",
  "mandatory_closing": "加油，有问题随时联系站里，再见",
  "forbidden_behaviors": [
    {
      "id": "fb_threaten",
      "description": "威胁骑手或使用侮辱性语言",
      "severity": "critical",
      "detection_keywords": [
        "不干就滚",
        "开除你",
        "扣你钱",
        "你不行"
      ]
    },
    {
      "id": "fb_exaggerate",
      "description": "夸大未达标后果（如编造罚款、影响信用等不存在的惩罚）",
      "severity": "major",
      "detection_keywords": [
        "罚款",
        "信用扣分",
        "永久取消",
        "黑名单"
      ]
    },
    {
      "id": "fb_lie_data",
