{
  "id": "outbound_merchant_policy_01",
  "name": "平台政策变更告知-商家配合型",
  "domain": "outbound_call",
  "call_type": "merchant_notify",
  "difficulty": "easy",
  "description": "客服致电餐饮商家，告知下月起配送费结算规则变更。商家配合度高，简单确认收到。",
  "call_purpose": "告知商家下月起配送费结算规则变更（从固定费率改为阶梯费率），确认商家理解新旧规则差异",
  "call_context": {
    "order_id": "",
    "customer_name": "王经理",
    "customer_phone": "13900139001",
    "order_items": [],
    "delivery_address": "朝阳区望京SOHO T2 B1层",
    "delivery_time": "",
    "issue_type": "",
    "issue_detail": "",
    "rider_name": "",
    "merchant_name": "鼎泰丰·国贸店",
    "compensation_budget": 0
  },
  "instruction_steps": [
    {
      "step_id": "open",
      "order": 1,
      "instruction": "自报身份（美团商家服务中心），说明来电目的（通知配送费结算规则调整）",
      "required_actions": [
        "self_identify",
        "state_purpose"
      ],
      "completion_condition": "商家应答表示在听"
    },
    {
      "step_id": "confirm_identity",
      "order": 2,
      "instruction": "确认对方是鼎泰丰·国贸店的王经理本人",
      "required_actions": [
        "confirm_name"
      ],
      "completion_condition": "商家确认身份"
    },
    {
      "step_id": "announce_policy",
      "order": 3,
      "instruction": "告知政策变更内容：下月1号起配送费结算从固定费率（每单4.5元）改为阶梯费率（月单量≤500单按4.5元，501-1000单按4.0元，1000单以上按3.5元），必须说明新旧规则差异和生效日期",
      "required_actions": [
        "explain_old_rule",
        "explain_new_rule",
        "state_effective_date"
      ],
      "completion_condition": "商家表示听到了政策内容"
    },
    {
      "step_id": "confirm_understanding",
      "order": 4,
      "instruction": "确认商家理解新规则，询问是否有疑问",
      "required_actions": [
        "check_understanding",
        "ask_questions"
      ],
      "branches": [
        {
          "condition": "商家理解无疑问",
          "next_step": "wrap_up",
          "description": "直接结束"
        },
        {
          "condition": "商家有疑问",
          "next_step": "answer_questions",
          "description": "解答疑问"
        }
      ],
      "completion_condition": "商家明确回复是否理解"
    },
    {
      "step_id": "answer_questions",
      "order": 5,
      "instruction": "解答商家关于新政策的疑问",
      "required_actions": [
        "answer_policy_questions"
      ],
      "is_optional": true,
      "completion_condition": "商家疑问得到解答"
    },
    {
      "step_id": "wrap_up",
      "order": 6,
      "instruction": "告知后续会通过商家版App推送正式通知，礼貌结束通话并记录结果",
      "required_actions": [
        "mention_app_notification",
        "say_goodbye",
        "log_result"
      ],
      "completion_condition": "通话结束"
    }
  ],
  "mandatory_opening": "您好，这里是美团商家服务中心",
  "mandatory_closing": "感谢您的配合，祝您生意兴隆，再见",
  "forbidden_behaviors": [
    {
      "id": "fb_threaten",
