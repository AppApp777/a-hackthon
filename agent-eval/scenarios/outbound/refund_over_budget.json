      "fact_description": "agent 告知客户当前授权补偿上限为50元",
      "check_turn": 5,
      "check_description": "agent 在后续拒绝超额请求时应始终坚守50元上限，不应在客户施压后擅自提高额度或给出模糊承诺",
      "keywords": [
        "50元",
        "授权范围",
        "上限",
        "最多"
      ]
    }
  ],
  "expected_db_state": {
    "call_logs": [
      {
        "order_id": "ORD202406001",
