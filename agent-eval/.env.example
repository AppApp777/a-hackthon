# LLM Provider: "anthropic", "openai", or "claude_cli" (default, requires claude CLI installed)
LLM_PROVIDER=anthropic

# Anthropic (required for --model claude-sonnet-4-6 / claude-opus-4-6)
ANTHROPIC_API_KEY=sk-ant-xxx

# OpenAI (or compatible like chat01.ai)
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.openai.com/v1

# LongCat (required for README quick-start examples)
# LONGCAT_API_KEY=ak_xxx

# MiMo
# MIMO_API_KEY=sk-xxx

# DeepSeek
# DEEPSEEK_API_KEY=sk-xxx

# MiniMax
# MINIMAX_API_KEY=xxx

# Kimi
# KIMI_API_KEY=xxx

# Bailian (Qwen)
# BAILIAN_API_KEY=sk-xxx

# GLM
# GLM_API_KEY=xxx

# Models (used by evaluation pipeline)
JUDGE_MODEL=claude-sonnet-4-6
AGENT_MODEL=claude-sonnet-4-6

# Evaluation
MAX_TURNS=20
FAULT_INJECTION_RATE=0.1
